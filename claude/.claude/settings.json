{
  "env": {
    "SHELL": "/usr/local/bin/bash"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git remote -v)",
      "Bash(tk *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(cat ~/.claude/references/*)",
      "Read(~/.claude/references/*)",
      "Bash(bash ~/dotfiles/scripts/tk-triage-context.sh *)",
      "Bash(qmd *)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${DOTFILES_DIR:-$HOME/dotfiles}/scripts/pkm-integrity-hook.sh --post-hook",
            "if": "Write(**/*.{temp,index,ref,synth}.md)|Edit(**/*.{temp,index,ref,synth}.md)"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "outputStyle": "explanatory",
  "effortLevel": "high",
  "editorMode": "vim"
}
